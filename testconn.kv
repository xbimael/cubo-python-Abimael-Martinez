BoxLayout:
    orientation: 'vertical'
    padding: 15
    spacing: 10

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '50dp'
        spacing: 10
        Button:
            text: "BUSCAR"
            size_hint_x: 0.2
            on_release: app.actualizar_puertos()
        Spinner:
            id: selector_puerto
            text: "Seleccionar Puerto"
            values: []
            size_hint_x: 0.5
        Button:
            id: btn_conectar
            text: "CONECTAR"
            size_hint_x: 0.3
            background_normal: ''
            background_color: 0, 0.6, 0.2, 1
            on_release: app.gestionar_conexion(selector_puerto.text)

    Label:
        id: estado_conexion
        text: "Estado: DESCONECTADO"
        size_hint_y: None
        height: '40dp'
        font_size: '16sp'
        color: 1, 1, 1, 1

    Widget: