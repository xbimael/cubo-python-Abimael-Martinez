<MonitorGrafico>:
    MDCard:
        orientation: 'vertical'
        radius: [dp(15),]     
        elevation: 0           
        padding: dp(10)
        spacing: dp(10)
        graph: graph_id

        MDBoxLayout:
            id: graph_container
            orientation: 'vertical'
            padding: dp(5)
            
            MDBoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(30)
                spacing: dp(15)
                padding: [0, 0, dp(15), 0]
                pos_hint: {"right": 1} # Alineada a la derecha

                Widget:
                    size_hint_x: 1

                MDCard:
                    size_hint: None, None
                    size: dp(210) if root.plot_ref.color[3] > 0 else dp(100), dp(24)
                    pos_hint: {'top': 0.97, 'right': 0.98}
                    md_bg_color: 1, 1, 1, 0.9
                    radius: [1,]
                    elevation: 0
                    orientation: 'horizontal'
                    padding: [dp(10), 0, dp(10), 0]
                    spacing: dp(15)
                    
                    # --- ESTO DIBUJA EL BORDE DEL RECUADRO ---
                    canvas.after:
                        Color:
                            rgba: 0.4, 0.4, 0.4, 0.8 
                        Line:
                            width: 1.1
                            rounded_rectangle: (self.x, self.y, self.width, self.height, self.height/2)

                    # Indicador Salida (Azul)
                    MDBoxLayout:
                        size_hint_x: None
                        width: dp(100)
                        spacing: dp(5)
                        Widget:
                            size_hint: None, None
                            size: dp(15), dp(3)
                            pos_hint: {"center_y": .5}
                            canvas:
                                Color:
                                    rgba: 0, 0.7, 1, 1 # Mismo azul que tu plot
                                Line:
                                    points: self.x, self.y + self.height/2, self.x + self.width, self.y + self.height/2
                                    width: 2
                        MDLabel:
                            text: "Output"
                            font_style: "Caption"
                            theme_text_color: "Secondary"

                    # Indicador Referencia (Rojo) - Solo si no es transparente
                    MDBoxLayout:
                        id: legend_ref
                        size_hint_x: None
                        width: dp(100)
                        spacing: dp(5)
                        opacity: 1 if root.plot_ref.color[3] > 0 else 0 # Desaparece en Open Loop
                        
                        Widget:
                            size_hint: None, None
                            size: dp(15), dp(3)
                            pos_hint: {"center_y": .5}
                            canvas:
                                Color:
                                    rgba: 1, 0, 0, 1 # Mismo rojo que tu plot_ref
                                Line:
                                    points: self.x, self.y + self.height/2, self.x + self.width, self.y + self.height/2
                                    width: 2
                        MDLabel:
                            text: "Reference"
                            font_style: "Caption"
                            theme_text_color: "Secondary"

                MDIconButton:
                    icon: "magnify-plus-outline"
                    pos_hint: {"right": 1}
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    md_bg_color: app.color_resaltado
                    size_hint: (None, None)
                    size: dp(20), dp(20)
                    on_release: root.abrir_grafico_externo()

            Graph:
                id: graph_id
                xlabel: 't (s)'
                ylabel: 'output'
                xmin: 0
                xmax: 10
                ymin: 0
                ymax: 1
                x_grid: True
                y_grid: True
                x_grid_label: True
                y_grid_label: True
                padding: dp(5)
                label_options: {'color': [0, 0, 0, 1], 'bold': True}
                background_color: 1, 1, 1, 1
                tick_color: 0.2, 0.2, 0.2, 1 
                border_color: 0, 0, 0, 1
                x_ticks_major: 1
                y_ticks_major: 0.1
                x_ticks_minor: 5
                y_ticks_minor: 5

        # Panel inferior de datos
        MDBoxLayout:
            size_hint_y: None
            height: self.minimum_height
            orientation: 'horizontal'
            padding: [dp(15), dp(10)]
            spacing: dp(10)
            radius: [dp(15),]
            elevation: 1
            md_bg_color: [1,1,1,1]

            MDFillRoundFlatButton:
                icon: "content-save"
                text: "SAVE RESULTS (.TXT)"
                md_bg_color: app.color_fondo_suave
                text_color: app.color_resaltado
                elevation: 0
                font_style: "Button"
                
                # Dibujamos el borde manualmente
                canvas.after:
                    Color:
                        rgba: app.color_borde
                    Line:
                        width: dp(1)
                        rounded_rectangle: (self.x, self.y, self.width, self.height, self.height/2)
                on_release: root.disparar_guardado()

            Widget:
                size_hint_x: 0.6

            MDCard:
                orientation: 'vertical'
                size_hint_x: 0.4
                md_bg_color: app.color_fondo_suave
                radius: [self.height / 2,]     
                elevation: 0           
                padding: dp(10)
                spacing: dp(10)

                MDLabel:
                    text: "SELECTED POINT"
                    theme_text_color: "Primary"
                    font_style: "Button"
                    font_size: dp(20)
                    halign: "center"
                    size_hint_y: None
                    height: dp(20)

                MDBoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(20)
                    spacing: dp(10)

                    MDLabel:
                        id: lbl_punto_x
                        text: "Time: --- s"
                        halign: "center"
                        font_style: "Caption"
                        theme_text_color: "Secondary"
                        font_size: dp(20)

                    MDLabel:
                        id: lbl_punto_y
                        text: "Output: --- rad/s"
                        halign: "center"
                        font_style: "Caption"
                        theme_text_color: "Secondary"
                        font_size: dp(20)

                