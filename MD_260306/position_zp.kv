<ModoPositionZP>:
    orientation: 'vertical'
    spacing: dp(10)
    padding: dp(20)

    MDLabel:
        text: "CONTROL DE POSICIÓN (ZEROS/POLES)"
        size_hint_y: None
        height: dp(40)
        halign: "center"
        font_style: "H6"
        theme_text_color: "Primary"

    # Contenedor para la fórmula LaTeX (Función de transferencia)
    MDBoxLayout:
        id: contenedor_export_latex
        size_hint_y: None
        height: dp(110)
        padding: dp(5)
        md_bg_color: (1, 1, 1, 0.03)
        radius: [dp(15),]

    # Grid de Parámetros del Controlador
    MDGridLayout:
        cols: 2
        spacing: dp(12)
        size_hint_y: None
        height: self.minimum_height

        MDTextField:
            id: k_in
            text: "1"
            hint_text: "Ganancia (K)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: c_in
            text: "0"
            hint_text: "Cero (C)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: p_in
            text: "0"
            hint_text: "Polo (P)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'
            
        MDTextField:
            id: ci_in
            text: "0"
            hint_text: "Cero integral (Ci)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'
            
        MDTextField:
            id: pi_in
            text: "0"
            hint_text: "Polo Integral (Pi)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: ref_in
            text: "3.14"
            hint_text: "Referencia (rad)"
            mode: "rectangle"
            icon_left: "target"
            input_filter: 'float'

    # Campo de tiempo destacado al final
    MDTextField:
        id: t_in
        text: "3"
        hint_text: "Tiempo de Simulación (s)"
        mode: "rectangle"
        icon_left: "timer-outline"
        input_filter: 'float'

    # Espacio para empujar el botón
    MDFloatLayout:
        size_hint_y: 1

    # Botón de acción principal
    MDRaisedButton:
        text: "EJECUTAR"
        size_hint_x: 0.95
        pos_hint: {"center_x": .5}
        md_bg_color: app.theme_cls.primary_color
        elevation: 4
        on_release: root.ejecutar_position_zp(k_in.text, c_in.text, p_in.text, ci_in.text, pi_in.text, ref_in.text, t_in.text)