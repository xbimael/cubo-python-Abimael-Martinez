# Estilo Global Material Design

# 1. Ajuste del fondo para todos los layouts de MD
<MDBoxLayout>, <MDFloatLayout>, <MDGridLayout>:
    md_bg_color: app.color_fondo_suave

# 2. Configuración de las Pestañas (MDTabs)
# No necesitas dibujar RoundedRectangles manualmente, MDTabs ya lo hace.
<MDTabs>:
    background_color: app.color_resaltado
    tab_hint_x: True
    allow_stretch: True
    indicator_color: 1, 1, 1, 1  # Línea blanca debajo de la pestaña activa
    text_color_normal: app.color_borde
    text_color_active: app.color_resaltado

# 3. Estilo para etiquetas de texto
<MDLabel>:
    theme_text_color: "Primary"
    font_style: "Body1"

# 4. Botones (Si quieres que todos tengan un estilo específico)
# Aunque usaremos MDRaisedButton, esto asegura que los normales no se vean feos
<Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: app.color_resaltado
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(4),]