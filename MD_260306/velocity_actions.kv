#:import MonitorGrafico monitor_grafico.MonitorGrafico

<ModoVelocityActions>:
    grafica_ref: grafico_ensayo
    orientation: 'horizontal'
    spacing: dp(15)
    padding: dp(20)

    MDCard:
        id: panel_izquierdo
        orientation: 'vertical'
        size_hint_x: 0.4
        md_bg_color: app.color_fondo_suave
        radius: [dp(15),]     
        elevation: 0           
        padding: dp(15)
        spacing: dp(10)

        MDLabel:
            text: "VELOCITY CONTROL (ACTIONS)"
            size_hint_y: None
            height: dp(40)
            halign: "center"
            font_style: "H6"
            theme_text_color: "Primary"

        Widget:
            size_hint_y: 0.1
            
        MDLabel:
            text: "This operation mode allows you to control the DC-motor by means of a PID controller written in term of the propotional, integral and derivative action"
            halign: "justify"
            font_style: "Body2"
            theme_text_color: "Secondary" # Gris profesional, no distrae
            size_hint_y: None
            height: self.texture_size[1] # Se ajusta solo al tamaño del texto
            padding: [dp(10), 0]

        Widget:
            size_hint_y: 0.1

        # Contenedor para la fórmula LaTeX
        MDBoxLayout:
            id: contenedor_export_latex
            size_hint_y: None
            height: dp(90)
            padding: dp(5)
            md_bg_color: (0, 0, 0, 0.1)
            radius: [dp(10),]

        Widget:
            size_hint_y: 0.1

        # Parámetros PID en cuadrícula
        MDGridLayout:
            cols: 2
            spacing: dp(12)
            size_hint_y: None
            height: self.minimum_height

            MDTextField:
                id: kp_input
                text: "1"
                hint_text: "Proportional constant, Kp"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: ki_input
                text: "0"
                hint_text:  "Integral constant, Ki"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: kd_input
                text: "0"
                hint_text:  "Derivative constant, Kd"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: ref_input
                text: "3.14"
                hint_text: "Velocity reference (rad/s)"
                mode: "rectangle"
                icon_left: "timer-outline"
                input_filter: 'float'

        # Campo de tiempo
        MDTextField:
            id: t_input
            text: "3"
            hint_text: "Experiment time (s)"
            mode: "rectangle"
            icon_left: "timer-sand"
            input_filter: 'float'

        # Espaciador
        MDFloatLayout:
            size_hint_y: 1

        # Botón de ejecución
        MDFillRoundFlatButton:
            id: btn_ejecutar
            text: "EXECUTE"
            font_style: "Button"
            elevation: 0          
            md_bg_color: app.color_resaltado
            text_color: 1, 1, 1, 1 
            on_release: root.ejecutar_velocity_actions(kp_input.text, ki_input.text, kd_input.text, ref_input.text, t_input.text)

    MDBoxLayout:
        MonitorGrafico:
            id: grafico_ensayo
            unidad_y: "rad/s"

    
