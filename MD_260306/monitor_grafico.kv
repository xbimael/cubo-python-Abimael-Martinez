<MonitorGrafico>:
    orientation: 'vertical'
    padding: dp(10)
    spacing: dp(10)
    graph: graph_id 

    MDBoxLayout:
        id: graph_container
        orientation: 'vertical'
        padding: dp(5)
        # No fijamos altura aquí para que el Graph use el espacio sobrante
        
        MDIconButton:
            icon: "magnify-plus-outline"
            pos_hint: {"right": 1}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            md_bg_color: app.theme_cls.primary_color
            size_hint: (None, None)
            size: dp(20), dp(20) # Un poco más grande para que sea pulsable
            on_release: root.abrir_grafico_externo()

        Graph:
            id: graph_id
            xlabel: 't (s)'
            ylabel: 'output'
            xmin: 0
            xmax: 10
            ymin: 0
            ymax: 1
            x_grid: True
            y_grid: True
            x_grid_label: True
            y_grid_label: True
            padding: dp(5)
            label_options: {'color': [0, 0, 0, 1], 'bold': True}
            background_color: 1, 1, 1, 1
            tick_color: 0.2, 0.2, 0.2, 1 
            border_color: 0, 0, 0, 1
            x_ticks_major: 1
            y_ticks_major: 0.1
            x_ticks_minor: 5
            y_ticks_minor: 5

    # Panel inferior de datos: Quitamos la altura fija de 60dp
    MDBoxLayout:
        size_hint_y: None
        height: self.minimum_height
        orientation: 'vertical'
        padding: [dp(15), dp(10)]
        spacing: dp(10)
        radius: [dp(15),]
        elevation: 1
        md_bg_color: [1,1,1,1]

        MDLabel:
            text: "SELECTED POINT"
            theme_text_color: "Primary"
            font_style: "Button"
            halign: "center"
            size_hint_y: None
            height: dp(10)

        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(10)
            spacing: dp(20)

            MDLabel:
                id: lbl_punto_x
                text: "Time: --- s"
                halign: "center"
                font_style: "Caption"
                theme_text_color: "Secondary"

            MDLabel:
                id: lbl_punto_y
                text: "Output: --- rad/s"
                halign: "center"
                font_style: "Caption"
                theme_text_color: "Secondary"

        MDSeparator:
            height: dp(1)

        MDRaisedButton:
            icon: "content-save"
            text: "SAVE RESULTS (.TXT)"
            pos_hint: {"center_x": .5}
            size_hint_x: 0.8
            md_bg_color: app.theme_cls.primary_color
            on_release: root.disparar_guardado()
