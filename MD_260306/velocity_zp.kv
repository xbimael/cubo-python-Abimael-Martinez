<ModoVelocityZP>:
    orientation: 'vertical'
    spacing: dp(10)
    padding: dp(20)

    MDLabel:
        text: "VELOCITY CONTROL (ZEROS/POLES)"
        size_hint_y: None
        height: dp(40)
        halign: "center"
        font_style: "H6"
        theme_text_color: "Primary"

    # Contenedor para la fórmula LaTeX
    MDBoxLayout:
        id: contenedor_export_latex
        size_hint_y: None
        height: dp(100)
        padding: dp(5)
        md_bg_color: (1, 1, 1, 1)
        radius: [dp(10),]

    # Parámetros del Controlador en Grid
    MDGridLayout:
        cols: 2
        spacing: dp(12)
        size_hint_y: None
        height: self.minimum_height

        MDTextField:
            id: k_input
            text: "1"
            hint_text: "Ganancia (K)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: c_input
            text: "0"
            hint_text: "Cero (C)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: p_input
            text: "0"
            hint_text: "Polo (P)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: ci_input
            text: "0"
            hint_text: "Cero Integral (Ci)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: pi_input
            text: "0"
            hint_text: "Polo Integral (Pi)"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: ref_input
            text: "3.14"
            hint_text: "Referencia (rad/s)"
            mode: "rectangle"
            icon_left: "timer-outline"
            input_filter: 'float'

    # Campo de tiempo destacado
    MDTextField:
        id: t_input
        text: "3"
        hint_text: "Tiempo de Simulación (s)"
        mode: "rectangle"
        icon_left: "timer-sand-complete"
        input_filter: 'float'

    MDFloatLayout:
        size_hint_y: 1

    # Botón de ejecución
    MDRaisedButton:
        text: "EJECUTAR ENSAYO"
        size_hint_x: 0.9
        pos_hint: {"center_x": .5}
        md_bg_color: 1, 0.6, 0.1, 1 # Naranja
        on_release: root.ejecutar_velocity_zp(k_input.text, c_input.text, p_input.text, ci_input.text, pi_input.text, ref_input.text, t_input.text)