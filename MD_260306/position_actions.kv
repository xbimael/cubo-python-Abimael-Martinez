#:import MonitorGrafico monitor_grafico.MonitorGrafico

<ModoPositionActions>:
    grafica_ref: grafico_ensayo
    orientation: 'horizontal'
    spacing: dp(15)
    padding: dp(20)

    MDBoxLayout:
        orientation: 'vertical'

        MDLabel:
            text: "POSITION CONTROL (ACTIONS)"
            size_hint_y: None
            height: dp(40)
            halign: "center"
            font_style: "H6"
            theme_text_color: "Primary"

        Widget:
            size_hint_y: 0.1
            
        MDLabel:
            text: "This operation mode allows you to control the DC-motor by means of a PID controller written in term of the propotional, integral and derivative action"
            halign: "justify"
            font_style: "Body2"
            theme_text_color: "Secondary" # Gris profesional, no distrae
            size_hint_y: None
            height: self.texture_size[1] # Se ajusta solo al tamaño del texto
            padding: [dp(10), 0]

        Widget:
            size_hint_y: 0.1

        # Contenedor para la fórmula LaTeX
        # Mantenemos el ID para que tu Python pueda inyectar la imagen
        MDBoxLayout:
            id: contenedor_export_latex
            size_hint_y: None
            height: dp(90)
            padding: dp(5)
            md_bg_color: (0, 0, 0, 0.1)
            radius: [dp(10),]

        Widget:
            size_hint_y: 0.1

        # Cuadrícula de parámetros PID
        MDGridLayout:
            cols: 2
            spacing: dp(15)
            size_hint_y: None
            height: self.minimum_height

            MDTextField:
                id: kp_input
                text: "1"
                hint_text: "Proportional constant, Kp"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: ki_input
                text: "0"
                hint_text: "Integral constant, Ki"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: kd_input
                text: "0"
                hint_text: "Derivative constant, Kd"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: ref_input
                text: "3.14"
                hint_text: "Position reference (rad)"
                mode: "rectangle"
                icon_left: "target"
                input_filter: 'float'

        # Campo de tiempo debajo de la cuadrícula
        MDTextField:
            id: t_input
            text: "3"
            hint_text: "Experiment time (s)"
            mode: "rectangle"
            icon_left: "timer-outline"
            input_filter: 'float'
            size_hint_y: None
            height: dp(60)

        # Espacio flexible
        MDFloatLayout:
            size_hint_y: 1

        # Botón de ejecución
        MDRaisedButton:
            id: btn_ejecutar
            text: "EXECUTE"
            size_hint_x: 0.8
            pos_hint: {"center_x": .5}
            md_bg_color: app.theme_cls.primary_color
            on_release: root.ejecutar_position_actions(kp_input.text, ki_input.text, kd_input.text, ref_input.text, t_input.text)

    MDBoxLayout:
        orientation: 'vertical'
        MonitorGrafico:
            id: grafico_ensayo
            unidad_y: "rad"
            size_hint_y: 0.6

        