<ModoPositionActions>:
    orientation: 'vertical'
    spacing: dp(15)
    padding: dp(20)

    MDLabel:
        text: "CONTROL DE POSICIÓN (ACTIONS)"
        size_hint_y: None
        height: dp(40)
        halign: "center"
        font_style: "H6"
        theme_text_color: "Primary"

    # Contenedor para la fórmula LaTeX
    # Mantenemos el ID para que tu Python pueda inyectar la imagen
    MDBoxLayout:
        id: contenedor_export_latex
        size_hint_y: None
        height: dp(100)
        padding: dp(5)
        md_bg_color: (1, 1, 1, 0.05) # Un fondo muy sutil para destacar la fórmula
        radius: [dp(10),]

    # Cuadrícula de parámetros PID
    MDGridLayout:
        cols: 2
        spacing: dp(15)
        size_hint_y: None
        height: self.minimum_height

        MDTextField:
            id: kp_input
            text: "1"
            hint_text: "Kp"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: ki_input
            text: "0"
            hint_text: "Ki"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: kd_input
            text: "0"
            hint_text: "Kd"
            mode: "rectangle"
            icon_left: 'blank'
            input_filter: 'float'

        MDTextField:
            id: ref_input
            text: "3.14"
            hint_text: "Referencia (rad)"
            mode: "rectangle"
            icon_left: "target"
            input_filter: 'float'

    # Campo de tiempo debajo de la cuadrícula
    MDTextField:
        id: t_input
        text: "3"
        hint_text: "Tiempo de Simulación (s)"
        mode: "rectangle"
        icon_left: "timer-outline"
        input_filter: 'float'
        size_hint_y: None
        height: dp(60)

    # Espacio flexible
    MDFloatLayout:
        size_hint_y: 1

    # Botón de ejecución
    MDRaisedButton:
        text: "EJECUTAR"
        size_hint_x: 0.9
        pos_hint: {"center_x": .5}
        md_bg_color: app.theme_cls.primary_color
        on_release: root.ejecutar_position_actions(kp_input.text, ki_input.text, kd_input.text, ref_input.text, t_input.text)