<ModoOpenLoop>:
    orientation: 'vertical'
    padding: dp(20)
    spacing: dp(15)

    MDLabel:
        text: "OPEN LOOP - LAZO ABIERTO"
        size_hint_y: None
        height: dp(40)
        halign: "center"
        font_style: "H6"
        theme_text_color: "Primary"

    # Contenedor de Inputs
    MDBoxLayout:
        orientation: 'vertical'
        size_hint_y: None
        height: self.minimum_height
        spacing: dp(12)

        MDTextField:
            id: v_input
            text: "10"
            hint_text: "Voltaje de Entrada (V)"
            helper_text: "Rango sugerido: -12V a 12V"
            helper_text_mode: "on_focus"
            mode: "rectangle" # Estilo caja moderna
            icon_left: "lightning-bolt"
            input_filter: 'float'

        # Espaciador
        MDFloatLayout:
            size_hint_y: 1

        MDTextField:
            id: t_input
            text: "3"
            hint_text: "Tiempo de Simulación (s)"
            helper_text: "Duración de la simulación"
            helper_text_mode: "on_focus"
            mode: "rectangle"
            icon_left: "timer-outline"
            input_filter: 'float'

    # Espaciador
    MDFloatLayout:
        size_hint_y: 1

    # Botón de ejecución
    MDRaisedButton:
        id: btn_ejecutar
        text: "EJECUTAR"
        size_hint_x: 0.9
        pos_hint: {"center_x": .5}
        md_bg_color: app.theme_cls.primary_color
        on_release: root.ejecutar_open_loop(v_input.text, t_input.text)