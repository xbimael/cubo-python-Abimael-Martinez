#:import MonitorGrafico monitor_grafico.MonitorGrafico

<ModoOpenLoop>:
    grafica_ref: grafico_ensayo
    orientation: 'horizontal'
    spacing: dp(15)
    padding: dp(20)

    MDBoxLayout:
        orientation: 'vertical'

        MDLabel:
            text: "OPEN LOOP RESPONSE"
            size_hint_y: None
            height: dp(40)
            halign: "center"
            font_style: "H6"
            theme_text_color: "Primary"

        Widget:
            size_hint_y: 0.1

        MDLabel:
            text: "Exciting the motor with several values input voltage allows to \nidentify the transfer function of the DC-motor."
            halign: "justify"
            font_style: "Body2"
            theme_text_color: "Secondary" # Gris profesional, no distrae
            size_hint_y: None
            height: self.texture_size[1] # Se ajusta solo al tamaño del texto
            padding: [dp(10), 0]

        Widget:
            size_hint_y: 0.1

        # Contenedor de Inputs
        MDBoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(10)

            MDTextField:
                id: v_input
                text: "10"
                hint_text: "Input Voltage (V)"
                helper_text: "Range: (-12,12) V"
                helper_text_mode: "on_focus"
                mode: "rectangle" # Estilo caja moderna
                icon_left: "lightning-bolt"
                input_filter: 'float'

            # Espaciador
            MDFloatLayout:
                size_hint_y: 1

            MDTextField:
                id: t_input
                text: "3"
                hint_text: "Experiment time (s)"
                helper_text: ""
                helper_text_mode: "on_focus"
                mode: "rectangle"
                icon_left: "timer-outline"
                input_filter: 'float'

        # Espaciador
        MDFloatLayout:
            size_hint_y: 1

        # Botón de ejecución
        MDRaisedButton:
            id: btn_ejecutar
            text: "EXECUTE"
            size_hint_x: 0.8
            pos_hint: {"center_x": .5}
            md_bg_color: app.theme_cls.primary_color
            on_release: root.ejecutar_open_loop(v_input.text, t_input.text)

    MDBoxLayout:
        orientation: 'vertical'
        MonitorGrafico:
            id: grafico_ensayo
            unidad_y: "rad/s"
            on_kv_post: self.plot_ref.color = [0, 0, 0, 0]
            size_hint_y: 0.6