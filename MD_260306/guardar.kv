<GuardarResultadosWidget>:
    # Usamos MDBoxLayout para mantener la estética Material
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(70) 
    padding: [dp(10), dp(5), dp(10), dp(20)] # Espacio inferior para no pegar al borde

    # Botón de guardado con icono y estilo redondeado
    MDFillRoundFlatIconButton:
        icon: "content-save-outline"
        text: "GUARDAR RESULTADOS (.txt)"
        font_size: '14sp'
        size_hint_x: 1  # Que ocupe todo el ancho del panel derecho
        
        # Color verde profesional (Material Success Color)
        md_bg_color: 0.1, 0.6, 0.2, 1 
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        icon_color: 1, 1, 1, 1
        
        on_release: root.guardar_txt()

    