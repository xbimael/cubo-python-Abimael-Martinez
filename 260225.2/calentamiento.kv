<ModoCalentamiento>:
    orientation: 'vertical'
    padding: 15
    spacing: 15

    Label:
        text: "CALENTAMIENTO"
        size_hint_y: None
        height: '40dp'
        bold: True
        color: app.AZUL

    GridLayout:
        cols: 2
        spacing: 10
        row_default_height: '35dp'
        row_force_default: True

        Label:
            text: "Tiempo Simulación (s):"
        TextInput:
            id: t_input
            text: "10"
            multiline: False
            input_filter: 'float'

    Widget:
        size_hint_y: 1

    Button:
        id: btn_ejecutar
        text: "EJECUTAR"
        size_hint_y: None
        height: '50dp'
        bold: True
        background_normal: ''
        background_color: app.AZUL
        on_release: root.ejecutar_modo(t_input.text)