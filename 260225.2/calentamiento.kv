<ModoCalentamiento>:
    orientation: 'vertical'
    padding: 20
    spacing: 15
    size_hint_y: None
    height: '200dp'

    canvas.before:
        Color:
            rgba: 0.2, 0.2, 0.2, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10,]

    Label:
        text: "MODO 1: CALENTAMIENTO"
        bold: True
        size_hint_y: None
        height: '30dp'

    BoxLayout:
        orientation: 'horizontal'
        spacing: 10
        size_hint_y: None
        height: '40dp'

        Label:
            text: "Tiempo (s):"
            size_hint_x: 0.4

        TextInput:
            id: tiempo_input
            text: "10"
            multiline: False
            input_filter: 'int'
            size_hint_x: 0.6

    Button:
        id: btn_ejecutar
        text: "INICIAR CALENTAMIENTO"
        on_release: root.ejecutar_modo(tiempo_input.text) # SIN paréntesis al final de la línea