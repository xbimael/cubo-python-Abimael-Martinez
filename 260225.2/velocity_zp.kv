<ModoVelocityZP>:
    orientation: 'vertical'
    padding: 15
    spacing: 15
    
    Label:
        text: "VELOCITY CONTROL (ZEROS/POLES)"
        size_hint_y: None
        height: '40dp'
        bold: True
        color: app.NARANJA

    BoxLayout:
        id: contenedor_export_latex
        size_hint_y: None
        height: '100dp'  # Ajusta según quieras de grande la fórmula
        
    GridLayout:
        cols: 2
        spacing: 10
        row_default_height: '35dp'
        row_force_default: True

        Label:
            text: "K:"
        TextInput:
            id: k_input
            text: "1"
            multiline: False
            input_filter: 'float'

        Label:
            text: "C:"
        TextInput:
            id: c_input
            text: "0"
            multiline: False
            input_filter: 'float'

        Label:
            text: "P:"
        TextInput:
            id: p_input
            text: "0"
            multiline: False
            input_filter: 'float'

        Label:
            text: "C_i:"
        TextInput:
            id: ci_input
            text: "0"
            multiline: False
            input_filter: 'float'

        Label:
            text: "P_i:"
        TextInput:
            id: pi_input
            text: "0"
            multiline: False
            input_filter: 'float'

        Label:
            text: "Ref (rad/s):"
        TextInput:
            id: ref_input
            text: "3.14"
            multiline: False
            input_filter: 'float'

        Label:
            text: "Tiempo (s):"
        TextInput:
            id: t_input
            text: "3"
            multiline: False
            input_filter: 'float'

    Widget:
        size_hint_y: 1

    Button:
        text: "EJECUTAR"
        size_hint_y: None
        height: '50dp'
        bold: True
        background_normal: ''
        background_color: app.NARANJA
        on_release: root.ejecutar_velocity_zp(k_input.text, c_input.text, p_input.text, ci_input.text, pi_input.text, ref_input.text, t_input.text)