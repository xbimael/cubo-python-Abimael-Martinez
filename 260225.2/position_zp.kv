<ModoPositionZP>:
    orientation: 'vertical'
    spacing: 15
    padding: 15

    Label:
        text: "POSITION CONTROL (Z/P)"
        bold: True
        size_hint_y: None
        height: '40dp'
        color: app.LILA

    GridLayout:
        cols: 2
        spacing: 10
        row_default_height: '35dp'
        row_force_default: True
        
        Label: 
            text: "K:"
        TextInput:
            id: k_in
            text: "1"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "C:"
        TextInput:
            id: c_in
            text: "0"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "P:"
        TextInput:
            id: p_in
            text: "0"
            multiline: False
            input_filter: 'float'
            
        Label: 
            text: "Ci:"
        TextInput:
            id: ci_in
            text: "0"
            multiline: False
            input_filter: 'float'
            
        Label: 
            text: "Pi:"
        TextInput:
            id: pi_in
            text: "0"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "Referencia (rad):"
        TextInput:
            id: ref_in
            text: "3.14"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "Tiempo (s):"
        TextInput:
            id: t_in
            text: "3"
            multiline: False
            input_filter: 'float'
    
    Widget: 
        size_hint_y: 1
    
    Button:
        text: "EJECUTAR"
        size_hint_y: None
        height: '50dp'
        background_normal: ''
        background_color: app.LILA
        on_release: root.ejecutar_position_zp(k_in.text, c_in.text, p_in.text, ci_in.text, pi_in.text, ref_in.text, t_in.text)