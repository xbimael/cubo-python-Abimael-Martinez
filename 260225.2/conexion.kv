<ConexionWidget>:
    orientation: 'vertical'
    size_hint_y: None
    height: '120dp'
    padding: 10
    spacing: 10
    BoxLayout:
        spacing: 10
        Button:
            text: "BUSCAR"
            size_hint_x: 0.2
            on_release: root.actualizar_puertos()
        Spinner:
            id: selector_puerto
            text: "Puerto"
            values: []
            size_hint_x: 0.5
        Button:
            id: btn_conectar
            text: "CONECTAR" if not root.arduino.conectado else "DESCONECTAR"
            size_hint_x: 0.3
            on_release: root.gestionar_conexion(selector_puerto.text)
    Label:
        id: estado_label
        text: "Estado: " + ("Conectado" if root.arduino.conectado else "Desconectado")
        color: (0, 1, 0, 1) if root.arduino.conectado else (1, 1, 1, 1)