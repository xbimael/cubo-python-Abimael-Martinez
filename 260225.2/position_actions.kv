<ModoPositionActions>:
    orientation: 'vertical'
    spacing: 10
    padding: 10

    Label:
        text: "POSITION CONTROL (ACTIONS)"
        bold: True
        size_hint_y: None
        height: '40dp'
        color: (0, 0.5, 0.8, 1) # Azul claro

    GridLayout:
        cols: 2
        spacing: 10
        row_default_height: '35dp'
        row_force_default: True
        
        Label: 
            text: "Kp:"
        TextInput:
            id: kp_input
            text: "1"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "Ki:"
        TextInput:
            id: ki_input
            text: "0"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "Kd:"
        TextInput:
            id: kd_input
            text: "0"
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "Referencia (rad):"
        TextInput:
            id: ref_input
            text: "3.14" # pi
            multiline: False
            input_filter: 'float'
        
        Label: 
            text: "Tiempo (s):"
        TextInput:
            id: t_input
            text: "5"
            multiline: False
            input_filter: 'float'
    
    Widget: 
        size_hint_y: 1
    
    Button:
        text: "EJECUTAR"
        size_hint_y: None
        height: '50dp'
        background_color: (0, 0.5, 0.8, 1)
        on_release: root.ejecutar_position_actions(kp_input.text, ki_input.text, kd_input.text, ref_input.text, t_input.text)