<MonitorGrafico>:
    orientation: 'vertical'
    padding: 10
    # Definimos las propiedades iniciales del Graph aquí
    graph: graph_id 

    BoxLayout:
        id: graph_container
        Graph:
            id: graph_id
            xlabel: 't (s)'
            ylabel: 'rad/s'
            xmin: 0
            xmax: 10
            ymin: 0
            ymax: 1
            x_grid: True
            y_grid: True
            x_grid_label: True
            y_grid_label: True
            padding: 5
            label_options: {'color': [1, 1, 1, 1], 'bold': True}
            # Podemos definir los ticks iniciales aquí
            x_ticks_major: 1      # Un número cada 1 segundo (antes era cada 5)
            y_ticks_major: 0.1    # Un número cada 0.1 unidades (antes era 0.2)
            x_ticks_minor: 5      # 5 subdivisiones entre números
            y_ticks_minor: 5      # 2 subdivisiones entre números