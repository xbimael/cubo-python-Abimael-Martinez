<MonitorGrafico>:
    orientation: 'vertical'
    padding: 10
    # Definimos las propiedades iniciales del Graph aquí
    graph: graph_id 

    BoxLayout:
        id: graph_container
        Graph:
            id: graph_id
            xlabel: 't (s)'
            ylabel: 'rad/s'
            xmin: 0
            xmax: 10
            ymin: 0
            ymax: 1
            x_grid: True
            y_grid: True
            x_grid_label: True
            y_grid_label: True
            padding: 5
            label_options: {'color': [1, 1, 1, 1], 'bold': True}
            # Podemos definir los ticks iniciales aquí
            x_ticks_major: 1      # Un número cada 1 segundo (antes era cada 5)
            y_ticks_major: 0.1    # Un número cada 0.1 unidades (antes era 0.2)
            x_ticks_minor: 5      # 5 subdivisiones entre números
            y_ticks_minor: 5      # 2 subdivisiones entre números

    BoxLayout:
        size_hint_y: None
        height: '60dp'
        orientation: 'horizontal'
        padding: [10, 5]
        spacing: 10
        canvas.before:
            Color:
                rgba: 0.15, 0.15, 0.15, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # Etiqueta de Título
        Label:
            text: "PUNTO SELECCIONADO:"
            color: 0, 0.7, 1, 1
            bold: True
            size_hint_x: 0.3

        # Valores de X e Y
        Label:
            id: lbl_punto_x
            text: "Tiempo: --- s"
            halign: 'left'
            text_size: self.size
            valign: 'middle'

        Label:
            id: lbl_punto_y
            text: "Valor: --- rad/s"
            halign: 'left'
            text_size: self.size
            valign: 'middle'