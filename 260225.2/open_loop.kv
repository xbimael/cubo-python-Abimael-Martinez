<ModoOpenLoop>:
    orientation: 'vertical'
    padding: 15
    spacing: 15
    
    Label:
        text: "CONFIGURACIÓN LAZO ABIERTO"
        size_hint_y: None
        height: '40dp'
        bold: True
        color: app.AZUL

    GridLayout:
        cols: 2
        spacing: 10
        row_default_height: '35dp'
        row_force_default: True

        Label:
            text: "Voltaje de Entrada (V):"
        TextInput:
            id: v_input
            text: "10"
            multiline: False
            input_filter: 'float'

        Label:
            text: "Tiempo Simulación (s):"
        TextInput:
            id: t_input
            text: "3"
            multiline: False
            input_filter: 'float'

    Widget:
        size_hint_y: 1

    Button:
        id: btn_ejecutar
        text: "EJECUTAR"
        size_hint_y: None
        height: '50dp'
        bold: True
        # Eliminada la dependencia de conexion_ref
        background_normal: ''
        background_color: app.AZUL
        on_release: root.ejecutar_open_loop(v_input.text, t_input.text)