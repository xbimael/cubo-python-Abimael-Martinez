#:include conexion.kv
#:include calentamiento.kv
#:include lazo_abierto.kv

BoxLayout:
    orientation: 'vertical'
    
    # Inyectamos el widget de conexión
    ConexionWidget:
        id: con_widget

    TabbedPanel:
        do_default_tab: False
        tab_width: self.width / 4

        TabbedPanelItem:
            text: 'CALENTAMIENTO'
            ModoCalentamiento:
                disabled: not app.conectado # Ahora reaccionará al instante

        TabbedPanelItem:
            text: 'OPEN LOOP'
            ModoOpenLoop:
                disabled: not con_widget.arduino.conectado