<ConexionWidget>:
    id: conexion_root  # <--- Le damos un nombre propio a la raíz del widget
    orientation: 'vertical'
    size_hint_y: None
    height: '100dp'
    padding: 10
    
    BoxLayout:
        orientation: 'horizontal'
        spacing: 10
        Button:
            text: "BUSCAR"
            size_hint_x: 0.2
            # Usamos el ID que acabamos de crear arriba en lugar de 'root'
            on_release: conexion_root.actualizar_puertos() 
        
        Spinner:
            id: selector_puerto
            text: "Seleccionar Puerto"
            size_hint_x: 0.4
            
        Button:
            id: btn_conectar
            text: "CONNECT"
            size_hint_x: 0.3
            on_release: conexion_root.gestionar_conexion(selector_puerto.text)

    Label:
        id: estado_conexion
        text: "Estado: Disconnected"