<ModoCalentamiento>:
    orientation: 'horizontal'
    spacing: dp(15)
    padding: dp(20)

    MDCard:
        id: panel_izquierdo
        orientation: 'vertical'
        size_hint_x: 0.4
        md_bg_color: app.color_fondo_suave
        radius: [dp(15),]       # Bordes redondeados
        elevation: 0            # Plano, como en tu nueva línea estética
        padding: dp(15)
        spacing: dp(10)

        MDLabel:
            text: "MOTOR WARM UP"
            size_hint_y: None
            height: dp(40)
            halign: "center"
            font_style: "H6"
            theme_text_color: "Primary"
        
        Widget:
            size_hint_y: 0.01

        MDLabel:
            text: "Some dynamic parameters of the motor change with the temperature. Warming up the motor aids to obtain homogenous results."
            halign: "justify"
            font_style: "Body2"
            theme_text_color: "Secondary" # Gris profesional, no distrae
            size_hint_y: None
            height: self.texture_size[1] # Se ajusta solo al tamaño del texto
            padding: [dp(10), 0]

        Widget:
            size_hint_y: 0.02
            
        # Contenedor para los parámetros
        MDTextField:
            id: t_input
            text: "10"
            hint_text: "Warm up time (s)"
            helper_text: "Recommended: 10 s"
            helper_text_mode: "on_focus"
            input_filter: 'float'
            mode: "rectangle"
            icon_left: "clock-outline" # Icono temático de reloj

        MDFloatLayout:
            size_hint_y: 0.02

        
        MDFloatLayout:
            size_hint_y: 1

        # Botón de acción con estilo Material
        MDFillRoundFlatButton:
            id: btn_ejecutar
            text: "WARM UP"
            font_style: "Button"
            elevation: 0        
            md_bg_color: app.color_resaltado
            text_color: 1, 1, 1, 1 
            on_release: root.ejecutar_modo(t_input.text)

    MDBoxLayout:
        Widget:
            size_hint_y: 0.1
