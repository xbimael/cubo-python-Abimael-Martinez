#:import MonitorGrafico monitor_grafico.MonitorGrafico

<ModoPositionZP>:
    grafica_ref: grafico_ensayo
    orientation: 'horizontal'
    spacing: dp(15)
    padding: dp(20)

    MDCard:
        id: panel_izquierdo
        orientation: 'vertical'
        size_hint_x: 0.4
        md_bg_color: app.color_fondo_suave
        radius: [dp(15),]     
        elevation: 0           
        padding: dp(15)
        spacing: dp(10)

        MDLabel:
            text: "POSITION CONTROL (ZEROS/POLES)"
            size_hint_y: None
            height: dp(40)
            halign: "center"
            font_style: "H6"
            theme_text_color: "Primary"

        Widget:
            size_hint_y: 0.01
            
        MDLabel:
            text: "This operation mode allows you to control the DC-motor by means of a PID controller defining its ceros and poles"
            halign: "justify"
            font_style: "Body2"
            theme_text_color: "Secondary" # Gris profesional, no distrae
            size_hint_y: None
            height: self.texture_size[1] # Se ajusta solo al tamaño del texto
            padding: [dp(10), 0]

        Widget:
            size_hint_y: 0.02

        # Contenedor para la fórmula LaTeX (Función de transferencia)
        MDBoxLayout:
            id: contenedor_export_latex
            size_hint_y: None
            height: dp(90)
            padding: dp(5)
            md_bg_color: (0, 0, 0, 0.1)
            radius: [dp(10),]

        Widget:
            size_hint_y: 0.02

        # Grid de Parámetros del Controlador
        MDGridLayout:
            cols: 2
            spacing: dp(12)
            size_hint_y: None
            height: self.minimum_height
            md_bg_color: app.color_fondo_suave

            MDTextField:
                id: k_in
                text: "1"
                hint_text: "Gain, K"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: c_in
                text: "0"
                hint_text: "Zero C"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: p_in
                text: "0"
                hint_text: "Pole, P"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'
                
            MDTextField:
                id: ci_in
                text: "0"
                hint_text: "Zero, Ci"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'
                
            MDTextField:
                id: pi_in
                text: "0"
                hint_text: "Pole, Pi"
                mode: "rectangle"
                icon_left: 'blank'
                input_filter: 'float'

            MDTextField:
                id: ref_in
                text: "3.14"
                hint_text: "Position reference (rad)"
                mode: "rectangle"
                icon_left: "target"
                input_filter: 'float'

            MDTextField:
                id: t_in
                text: "3"
                hint_text: "Experiment time (s)"
                mode: "rectangle"
                icon_left: "timer-sand"
                input_filter: 'float'

            MDTextField:
                id: tsam_input
                text: "10"
                hint_text: "Sample time (ms)"
                helper_text: ""
                helper_text_mode: "on_focus"
                mode: "rectangle"
                icon_left: "timer-outline"
                input_filter: 'float'

        # Espacio para empujar el botón
        MDFloatLayout:
            size_hint_y: 1

        # Botón de ejecución
        MDFillRoundFlatButton:
            id: btn_ejecutar
            text: "EXECUTE"
            font_style: "Button"
            elevation: 0          
            md_bg_color: app.color_resaltado
            text_color: 1, 1, 1, 1 
            on_release: root.ejecutar_position_zp(k_in.text, c_in.text, p_in.text, ci_in.text, pi_in.text, ref_in.text, t_in.text, tsam_input.text)

    MDBoxLayout:
        orientation: 'vertical'
        MonitorGrafico:
            id: grafico_ensayo
            unidad_y: "rad"
            size_hint_y: 0.6