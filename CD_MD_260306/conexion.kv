<ConexionWidget>:
    MDBoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.8
        spacing: dp(2)        # Espacio mínimo entre título y subtítulo
        padding: [dp(20), 0, 0, 0] # Margen a la izquierda para que no pegue al borde
        pos_hint: {"center_y": .5}

        MDLabel:
            text: "Competence: Control Engineering"
            font_style: "H5"
            theme_text_color: "Custom"
            text_color: app.color_resaltado
            size_hint_y: None
            height: self.texture_size[1]
            bold: True

        MDLabel:
            text: "Discrete Control"
            font_style: "Overline"     
            theme_text_color: "Custom"
            text_color: app.color_borde
            size_hint_y: None
            height: self.texture_size[1]
            bold: True

    MDCard:
        id: panel_superior
        orientation: 'vertical'
        size_hint_x: 0.3
        radius: [self.height/2,]     
        elevation: 0           
        padding: dp(10)
        spacing: dp(10)

        MDBoxLayout:
            spacing: dp(15)
            orientation: 'horizontal'

            MDFillRoundFlatButton:
                id: selector_puerto
                text: "SELECT SERIAL PORT"
                size_hint_y: None
                height: dp(48) # Altura estándar de Material Design
                size_hint_x: 1 # Ocupa todo el ancho disponible
                md_bg_color: 0,0,0,0
                text_color: app.color_resaltado
                canvas.after:
                    Color:
                        rgba: app.color_borde
                    Line:
                        width: dp(1)
                        rounded_rectangle: (self.x, self.y, self.width, self.height, self.height/2)
                on_release: root.abrir_menu_puertos(self)
                
            # Botón con icono de refrescar
            MDFillRoundFlatButton:
                text: "REFRESH"
                icon: "refresh"
                # size_hint_x: 0.2
                md_bg_color: app.color_fondo_suave
                text_color: app.color_resaltado
                elevation: 0
                font_style: "Button"
                
                # Dibujamos el borde manualmente
                canvas.after:
                    Color:
                        rgba: app.color_borde
                    Line:
                        width: dp(1)
                        rounded_rectangle: (self.x, self.y, self.width, self.height, self.height/2)
                on_release: root.actualizar_puertos()

            # Botón de Conexión dinámico
            MDFillRoundFlatButton:
                id: btn_conectar
                text: "CONNECT" if not root.arduino.conectado else "DISCONNECT"
                # size_hint_x: 0.2
                elevation: 0
                font_style: "Button"
                md_bg_color: app.color_resaltado if not root.arduino.conectado else app.color_fondo_suave
                text_color: app.color_fondo_suave if not root.arduino.conectado else app.color_resaltado
                
                canvas.after:
                    Color:
                        rgba: app.color_borde
                    Line:
                        width: dp(0.01) if not root.arduino.conectado else dp(1)
                        rounded_rectangle: (self.x, self.y, self.width, self.height, self.height/2)

                on_release: root.gestionar_conexion(selector_puerto.text)

    


<CustomSpinnerOption@SpinnerOption>:
    # El botón de cada opción dentro del menú
    background_normal: ''
    background_color: 0, 0, 0, 0  # Fondo transparente para usar el canvas
    color: app.color_borde        # Texto verde teal
    font_size: '14sp'
    height: dp(45)

    canvas.before:
        Color:
            rgba: app.color_fondo_suave
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10),]     # Un poco menos que el botón principal para que encaje bien

<CustomDropDown@DropDown>:
    canvas.before:
        Color:
            rgba: app.color_borde # Un borde fino alrededor de todo el menú
        Line:
            width: dp(1)
            rounded_rectangle: (self.x, self.y, self.width, self.height, self.height/2)
