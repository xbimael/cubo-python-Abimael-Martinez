#:import TabbedPanel kivy.uix.tabbedpanel.TabbedPanel

BoxLayout:
    orientation: 'vertical'
    padding: 10
    spacing: 5
    canvas.before:
        Color:
            rgba: 0.1, 0.1, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # --- CABECERA DE CONEXIÓN ---
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '60dp'
        padding: 5
        spacing: 10
        
        Button:
            text: "BUSCAR"
            size_hint_x: 0.2
            on_release: app.actualizar_puertos()
            
        Spinner:
            id: selector_puerto
            text: "Seleccionar Puerto"
            values: []
            size_hint_x: 0.4
            
        Button:
            id: btn_conectar
            text: "CONNECT"
            size_hint_x: 0.3
            background_normal: ''
            background_color: 0, 0.6, 0.2, 1
            on_release: app.gestionar_conexion(selector_puerto.text)

    # --- ETIQUETA DE ESTADO (ESTE ES EL ID QUE FALTABA) ---
    Label:
        id: estado_conexion
        text: "Estado: Disconnected"
        size_hint_y: None
        height: '30dp'
        font_size: '14sp'
        color: 1, 1, 1, 1

    # --- PANEL DE PESTAÑAS ---
    TabbedPanel:
        id: panel_principal
        do_default_tab: False
        tab_width: self.width / 4  
        background_color: 0, 0, 0, 0

        # PESTAÑA 1: CALENTAMIENTO
        TabbedPanelItem:
            text: 'CALENTAMIENTO'
            BoxLayout:
                orientation: 'vertical'
                padding: 20
                spacing: 20
                disabled: btn_conectar.text != "DISCONNECT"
                Label:
                    text: "MODO 1: CALENTAMIENTO"
                    bold: True
                BoxLayout:
                    size_hint_y: None
                    height: '40dp'
                    Label: text: "Tiempo (s):"
                    TextInput:
                        id: tiempo_calentamiento
                        text: "10"
                        input_filter: 'int'
                        multiline: False
                Button:
                    text: "INICIAR"
                    on_release: app.ejecutar_calentamiento(tiempo_calentamiento.text)
                Widget:

        # PESTAÑA 2: OPEN LOOP
        TabbedPanelItem:
            text: 'OPEN LOOP'
            BoxLayout:
                orientation: 'vertical'
                padding: 20
                spacing: 20
                disabled: btn_conectar.text != "DISCONNECT"
                Label:
                    text: "MODO 2: OPEN LOOP RESPONSE"
                    bold: True
                BoxLayout:
                    size_hint_y: None
                    height: '40dp'
                    Label: text: "Tiempo (s):"
                    TextInput:
                        id: tiempo_open_loop
                        text: "20"
                        input_filter: 'int'
                        multiline: False
                Button:
                    text: "INICIAR"
                    on_release: app.ejecutar_open_loop(tiempo_open_loop.text)
                Widget:

        # PESTAÑA 3: CONTROL PID (Vacía)
        TabbedPanelItem:
            text: 'CONTROL PID'
            Label: text: "Modo 3"

        # PESTAÑA 4: MONITOR (Vacía)
        TabbedPanelItem:
            text: 'MONITOR'
            Label: text: "Monitor Serial"